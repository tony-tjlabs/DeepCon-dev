# DeepCon Dashboard - Streamlit Secrets Template
# =============================================
# 이 파일은 Streamlit Cloud Settings -> Secrets에 입력할 내용의 예시입니다.
# 실제 배포 시 <YOUR_...> 부분을 실제 값으로 교체하세요.
# 주의: 이 파일을 .env나 secrets.toml로 저장하지 마세요 (gitignore 대상)

# ─── 배포 모드 ───────────────────────────────────────
CLOUD_MODE = "true"

# ─── 계정 비밀번호 해시 (argon2id, v3 M1~) ─────────────
# 평문 저장 금지. argon2id 해시만 사용한다.
#
# 해시 생성 예시:
#   python -c "from argon2 import PasswordHasher; print(PasswordHasher().hash('<PLAIN>'))"
# 또는 `scripts/rotate_passwords.py` 사용.
#
# 기존 평문 필드 DEEPCON_*_PASSWORD 는 Upgrade v3 M1 에서 제거됨. 더 이상 참조되지 않음.
DEEPCON_ADMIN_PW_HASH = "<YOUR_ADMIN_ARGON2ID_HASH>"
DEEPCON_Y1_PW_HASH    = "<YOUR_Y1_ARGON2ID_HASH>"
DEEPCON_M15X_PW_HASH  = "<YOUR_M15X_ARGON2ID_HASH>"

# ─── user_no alias salt (v3 M2-B) ───────────────────────────
# core.security.anonymizer.core.mask_user_no 가 사용. 랜덤 32자로 설정.
# 바꾸면 기존 alias (A-xxxxx) 가 깨지므로 한 번 정하면 유지할 것.
DEEPCON_USER_NO_SALT = "<YOUR_32CHAR_RANDOM_SALT>"

# ─── LLM 설정 (선택) ─────────────────────────────────
# Anthropic API 사용 시
ANTHROPIC_API_KEY = "<YOUR_ANTHROPIC_API_KEY>"
LLM_BACKEND = "anthropic"

# AWS Bedrock 사용 시 (Anthropic 대신)
# LLM_BACKEND = "bedrock"
# AWS_REGION = "ap-northeast-2"
# AWS_BEDROCK_MODEL_ID = "anthropic.claude-sonnet-4-6-v1"

# ─── 보안 설정 (기본값 유지 권장) ─────────────────────
SECURE_MODE = "true"
ANONYMIZE_LLM = "true"
ANONYMIZE_LOGIC = "true"

# ─── Google Drive 연동 ───────────────────────────────
GDRIVE_FOLDER_ID = "<YOUR_DRIVE_FOLDER_ID>"

# Service Account JSON (TOML 형식)
[gcp_service_account]
type = "service_account"
project_id = "<YOUR_PROJECT_ID>"
private_key_id = "<YOUR_PRIVATE_KEY_ID>"
private_key = "-----BEGIN PRIVATE KEY-----\n<YOUR_PRIVATE_KEY>\n-----END PRIVATE KEY-----\n"
client_email = "<YOUR_SERVICE_ACCOUNT_EMAIL>"
client_id = "<YOUR_CLIENT_ID>"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "<YOUR_CERT_URL>"
